{
  "name": "bungraph",
  "version": "0.1.20",
  "description": "Turnkey temporal context graph (Graphiti 1:1 port) on libsql. Uses your local Claude Code CLI — no API keys. Single bunx command. MCP + HTTP + CLI.",
  "type": "module",
  "bin": {
    "bungraph": "./bin/bundag.js"
  },
  "main": "src/index.js",
  "files": [
    "bin",
    "src",
    "models",
    "mcp.js",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AnEntrypoint/bundag.git"
  },
  "bugs": {
    "url": "https://github.com/AnEntrypoint/bundag/issues"
  },
  "homepage": "https://github.com/AnEntrypoint/bundag#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node ./bin/bundag.js",
    "test": "node test.js"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.19.0",
    "@huggingface/transformers": "^3.8.1",
    "@libsql/client": "^0.15.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "lru-cache": "^11.0.0",
    "onnxruntime-node": "^1.23.2",
    "onnxruntime-web": "^1.19.0",
    "uuid": "^10.0.0",
    "zod": "^3.25.0"
  },
  "keywords": [
    "graphiti",
    "knowledge-graph",
    "temporal",
    "libsql",
    "mcp",
    "memory",
    "agent",
    "claude-code"
  ],
  "license": "Apache-2.0",
  "pkg": {
    "scripts": [
      "src/**/*.js",
      "bin/**/*.js"
    ],
    "assets": [
      "node_modules/@libsql/**/*",
      "node_modules/@huggingface/transformers/dist/**/*",
      "node_modules/@huggingface/transformers/node_modules/onnxruntime-node/bin/**/*",
      "node_modules/onnxruntime-node/bin/**/*",
      "node_modules/onnxruntime-web/dist/**/*"
    ]
  }
}
